# ── logMasterDaemon ───────────────────────────────────────────────────────────
# Shared secret — must match LOG_API_SHARED_SECRET in logMasterServer's .env
LOG_API_SHARED_SECRET=change-me-to-a-strong-shared-secret

# Port the daemon listens on
LOG_API_PORT=5001

# Set to true only during development
FLASK_DEBUG=false
